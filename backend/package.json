{
  "name": "@onluyenphongvan/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/main",
    "start": "node dist/main",
    "start:dev": "tsc -w & node dist/main",
    "seed": "tsc && node dist/scripts/seed.js",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@nestjs/common": "^11.0.10",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.10",
    "@nestjs/cqrs": "^11.0.2",
    "@nestjs/mongoose": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.10",
    "@nestjs/platform-socket.io": "^11.0.10",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/websockets": "^11.0.10",
    "@onluyenphongvan/types": "workspace:*",
    "bullmq": "^5.41.4",
    "fastify": "^5.2.1",
    "ioredis": "^5.5.0",
    "meilisearch": "^0.47.0",
    "mongoose": "^8.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@onluyenphongvan/config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "22.14.0"
  }
}
