{
  "name": "onluyenphongvan-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend Interview Platform - High performance, AI-first, Clean Architecture monorepo",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @onluyenphongvan/backend run dev",
    "dev:frontend": "pnpm --filter @onluyenphongvan/frontend run dev",
    "build:backend": "pnpm --filter @onluyenphongvan/backend run build",
    "start:backend": "node backend/dist/main"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "eslint": "^9.21.0"
  },
  "engines": {
    "node": "22.14.0",
    "pnpm": ">=9.0.0"
  }
}
